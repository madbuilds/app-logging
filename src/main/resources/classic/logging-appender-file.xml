<?xml version="1.0" encoding="UTF-8"?>
<included>
    <springProperty name="IS_FILE_APPENDER_ENABLED" source="app.logging.appender.file.enabled" defaultValue="false"/>
    <condition class="ch.qos.logback.core.boolex.PropertyEqualityCondition">
        <key>IS_FILE_APPENDER_ENABLED</key>
        <value>true</value>
    </condition>
    <if>
        <then>
            <springProperty name="LOG_FILE" source="app.logging.appender.file.name" defaultValue="app.log"/>
            <springProperty name="FILE_APPENDER_LAYOUT" source="app.logging.appender.file.layout" defaultValue="default"/>

            <!-- IF LAYOUT = DEFAULT -->
            <condition class="com.github.mad.logging.internal.condition.PropertyEqualsNoCaseCondition">
                <key>FILE_APPENDER_LAYOUT</key>
                <value>default</value>
            </condition>
            <if>
                <then>
                    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
                    <include resource="org/springframework/boot/logging/logback/file-appender.xml"/>

                    <appender name="ASYNC_FILE_APPENDER" class="ch.qos.logback.classic.AsyncAppender">
                        <appender-ref ref="FILE"/>
                    </appender>
                </then>
            </if>

            <!-- IF LAYOUT = JSON -->
            <condition class="com.github.mad.logging.internal.condition.PropertyEqualsNoCaseCondition">
                <key>FILE_APPENDER_LAYOUT</key>
                <value>json</value>
            </condition>
            <if>
                <then>
                    <appender name="FILE_JSON_APPENDER" class="ch.qos.logback.core.rolling.RollingFileAppender">
                        <file>${LOG_FILE}</file>
                        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.log</fileNamePattern>
                            <maxHistory>30</maxHistory>
                        </rollingPolicy>
                        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSX</timestampPattern>
                            <timeZone>CET</timeZone>
                            <messageSplitRegex>SYSTEM</messageSplitRegex>
                            <provider class="net.logstash.logback.composite.loggingevent.LoggingEventPatternJsonProvider">
                                <pattern>
                                    {
                                    "message": "%message"
                                    }
                                </pattern>
                            </provider>
                            <fieldNames>
                                <timestamp>timestamp</timestamp>
                                <version>@version</version>
                                <level>level</level>
                                <logger>logger</logger>
                                <thread>thread</thread>
                                <message>[ignore]</message>
                                <levelValue>level_value</levelValue>
                                <stackTrace>stacktrace</stackTrace>
                                <mdc>mdc</mdc>
                                <context>context</context>
                                <caller>caller</caller>
                            </fieldNames>
                        </encoder>
                    </appender>
                    <appender name="ASYNC_FILE_APPENDER" class="ch.qos.logback.classic.AsyncAppender">
                        <appender-ref ref="FILE_JSON_APPENDER"/>
                    </appender>
                </then>
            </if>
        </then>
    </if>
</included>