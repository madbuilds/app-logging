<?xml version="1.0" encoding="UTF-8"?>
<included>
    <springProperty name="IS_FILE_APPENDER_ENABLED" source="app.logging.appender.file.enabled" defaultValue="false"/>
    <condition class="ch.qos.logback.core.boolex.PropertyEqualityCondition">
        <key>IS_FILE_APPENDER_ENABLED</key>
        <value>true</value>
    </condition>
    <if>
        <then>
            <springProperty name="LOG_FILE" source="app.logging.appender.file.name" defaultValue="app.log"/>

            <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
            <include resource="org/springframework/boot/logging/logback/file-appender.xml"/>

            <appender name="ASYNC_FILE_APPENDER" class="ch.qos.logback.classic.AsyncAppender">
                <appender-ref ref="FILE"/>
            </appender>
        </then>
    </if>
</included>